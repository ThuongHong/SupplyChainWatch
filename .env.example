APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=globalsupplywatch
POSTGRES_USER=globalsupplywatch
POSTGRES_PASSWORD=globalsupplywatch
DATABASE_URL=postgresql+psycopg://globalsupplywatch:globalsupplywatch@postgres:5432/globalsupplywatch
ASYNC_DATABASE_URL=postgresql+psycopg://globalsupplywatch:globalsupplywatch@postgres:5432/globalsupplywatch

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

BACKEND_DEMO_FALLBACK_ENABLED=false
VITE_ENABLE_DEMO_FALLBACK=false
PORTWATCH_HISTORY_DAYS=180
RISK_STORY_MIN_HISTORY_DAYS=90
RISK_FORECAST_MIN_HISTORY_DAYS=14
RISK_STORY_Z_THRESHOLD=2.0
RISK_STORY_PERCENT_CHANGE_THRESHOLD=35.0
RISK_FORECAST_HORIZON_DAYS=14
RISK_FORECAST_MAX_GAP_RATE=0.35

AISSTREAM_API_KEY=
FRED_API_KEY=
UN_COMTRADE_API_KEY=
WORLD_BANK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL_FAST=qwen3.5-flash
LLM_MODEL_FAST_FALLBACKS=qwen3.5-flash-2026-02-23
LLM_MODEL_REASONING=deepseek-v4-flash
LLM_MODEL_REASONING_FALLBACKS=qwen3.5-flash,qwen3.5-flash-2026-02-23
LLM_ENABLED=true
LLM_TIMEOUT_FAST=30
LLM_TIMEOUT_REASONING=60

SCRAPER_USER_AGENT=GlobalSupplyWatch/0.1 academic project contact@example.com
